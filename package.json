{
  "name": "realmork",
  "version": "0.1.0",
  "private": true,
  "description": "Homework manager desktop app built with Go, Electron, and React.",
  "main": "electron/main.js",
  "type": "module",
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.4.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.0",
    "cross-env": "^10.0.0",
    "electron": "^37.4.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  },
  "scripts": {
    "dev": "npm run dev:backend && cross-env NODE_ENV=development ELECTRON_RENDERER_URL=http://127.0.0.1:5173 concurrently \"vite --host 127.0.0.1 --strictPort\" \"npm:dev:electron\"",
    "dev:backend": "mkdir -p dist/bin && go build -o dist/bin/homeworkd ./cmd/homeworkd",
    "dev:electron": "wait-on tcp:5173 file:dist/bin/homeworkd && electron .",
    "start": "electron .",
    "build:renderer": "vite build",
    "build:backend": "mkdir -p dist/bin && go build -o dist/bin/homeworkd ./cmd/homeworkd",
    "build": "npm run build:renderer && npm run build:backend",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  }
}
